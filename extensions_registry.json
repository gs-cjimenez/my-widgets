{
  "widgets": [
    {
      "type": "spotlight_experts",
      "title": "Spotlight Experts",
      "version": "1.0.0",
      "description": "Highlights community members recognized as experts in statistical analysis.",
      "category": "Custom",
      "imageName": "spotlight_experts",
      "containers": ["Full width"],
      "widgetsLibrary": true,
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": false,
        "movable": true
      },
      "connectors": ["spotlight-users"],
      "source": {
        "path": "widgets/spotlight_experts/dist",
        "entry": "content.html"
      },
      "configuration": {
        "properties": [
          {
            "name": "sectionTitle",
            "type": "text",
            "label": "Section Title",
            "defaultValue": "Statistical Analysis Experts"
          },
          {
            "name": "sectionSubtitle",
            "type": "text",
            "label": "Section Subtitle",
            "defaultValue": "Meet the community members recognized for their expertise in statistical analysis. These individuals have demonstrated exceptional knowledge and a commitment to helping others master the art of data-driven discovery."
          }
        ]
      }
    },
    {
      "type": "event_banner",
      "title": "Event Banner",
      "version": "1.0.0",
      "description": "A full-width event promotion banner with configurable title, description, CTA button, background color, image, and badge.",
      "category": "widgets",
      "containers": ["Full width"],
      "widgetsLibrary": true,
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": false,
        "movable": true
      },
      "source": {
        "path": "widgets/event_banner",
        "entry": "index.html"
      },
      "configuration": {
        "properties": [
          {
            "name": "title",
            "type": "text",
            "label": "Event Title",
            "defaultValue": "Ask Microsoft Anything: The Microsoft Sentinel SIEM Migration Experience on June 23"
          },
          {
            "name": "description",
            "type": "text",
            "label": "Description",
            "defaultValue": "Join us for a live demo and AMA on the Microsoft Sentinel SIEM migration experience. We'll cover what it does today, how it works, and the questions customers ask most, then open it up for live Q&A."
          },
          {
            "name": "buttonText",
            "type": "text",
            "label": "Button Text",
            "defaultValue": "RSVP Here"
          },
          {
            "name": "buttonUrl",
            "type": "text",
            "label": "Button URL",
            "defaultValue": "https://techcommunity.microsoft.com/event/microsoft-security-events/ask-microsoft-anything-the-microsoft-sentinel-siem-migration-experience/4521635"
          },
          {
            "name": "backgroundColor",
            "type": "color",
            "label": "Background Color",
            "defaultValue": "#0078D4"
          },
          {
            "name": "imageUrl",
            "type": "text",
            "label": "Image URL (leave blank to hide)",
            "defaultValue": ""
          },
          {
            "name": "badgeText",
            "type": "text",
            "label": "Badge Text (leave blank to hide)",
            "defaultValue": "#Event"
          }
        ]
      },
      "defaultConfig": {
        "title": "Ask Microsoft Anything: The Microsoft Sentinel SIEM Migration Experience on June 23",
        "description": "Join us for a live demo and AMA on the Microsoft Sentinel SIEM migration experience. We'll cover what it does today, how it works, and the questions customers ask most, then open it up for live Q&A.",
        "buttonText": "RSVP Here",
        "buttonUrl": "https://techcommunity.microsoft.com/event/microsoft-security-events/ask-microsoft-anything-the-microsoft-sentinel-siem-migration-experience/4521635",
        "backgroundColor": "#0078D4",
        "imageUrl": "",
        "badgeText": "#Event"
      }
    },
    {
      "version": "1.0.0",
      "title": "Learning Path Banner",
      "type": "demo_learning_path_banner",
      "description": "A compact banner promoting a new learning path or course with icon, badge, title, and CTA button.",
      "category": "widgets",
      "containers": ["Full width"],
      "widgetsLibrary": true,
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": false,
        "movable": true
      },
      "source": {
        "path": "widgets/learning_path_banner",
        "entry": "index.html"
      },
      "configuration": {
        "properties": [
          {
            "name": "badgeLabel",
            "type": "text",
            "label": "Badge Label",
            "defaultValue": "NEW LEARNING PATH"
          },
          {
            "name": "iconUrl",
            "type": "text",
            "label": "Course Icon URL (leave blank for letter fallback)",
            "defaultValue": ""
          },
          {
            "name": "courseTitle",
            "type": "text",
            "label": "Course Title",
            "defaultValue": "Analytics Fundamentals Accreditation"
          },
          {
            "name": "buttonText",
            "type": "text",
            "label": "Button Text",
            "defaultValue": "Explore Now"
          },
          {
            "name": "buttonUrl",
            "type": "text",
            "label": "Button URL",
            "defaultValue": "https://www.databricks.com/resources/learn/training/analytics-fundamentals-accreditation"
          },
          {
            "name": "accentColor",
            "type": "color",
            "label": "Accent Color",
            "defaultValue": "#FF3621"
          }
        ]
      },
      "defaultConfig": {
        "badgeLabel": "NEW LEARNING PATH",
        "iconUrl": "",
        "courseTitle": "Analytics Fundamentals Accreditation",
        "buttonText": "Explore Now",
        "buttonUrl": "https://www.databricks.com/resources/learn/training/analytics-fundamentals-accreditation",
        "accentColor": "#FF3621"
      }
    }
  ]
}
